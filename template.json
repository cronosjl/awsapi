AWSTemplateFormatVersion: '2010-09-09'
Resources:
  # L'API Gateway
  MissionApi:
    Type: 'AWS::ApiGateway::RestApi'
    Properties:
      Name: 'MissionApi'

  # La fonction de récupération de produits (Code inclus directement)
  GetProductsFunction:
    Type: 'AWS::Lambda::Function'
    Properties:
      FunctionName: get_products_direct
      Handler: index.lambda_handler
      Runtime: python3.11
      Role: arn:aws:iam::907354788138:role/LabRole
      Code:
        ZipFile: |
          import json
          def lambda_handler(event, context):
              return {
                  'statusCode': 200,
                  'body': json.dumps([{'id': 1, 'name': 'Produit Lab'}])
              }

  # Permission pour l'API d'appeler la Lambda
  LambdaPermission:
    Type: 'AWS::Lambda::Permission'
    Properties:
      Action: 'lambda:InvokeFunction'
      FunctionName: !Ref GetProductsFunction
      Principal: apigateway.amazonaws.com

  # Route API /products
  ApiResource:
    Type: 'AWS::ApiGateway::Resource'
    Properties:
      ParentId: !GetAtt MissionApi.RootResourceId
      PathPart: 'products'
      RestApiId: !Ref MissionApi

  ApiMethod:
    Type: 'AWS::ApiGateway::Method'
    Properties:
      AuthorizationType: NONE
      HttpMethod: GET
      ResourceId: !Ref ApiResource
      RestApiId: !Ref MissionApi
      Integration:
        Type: AWS_PROXY
        IntegrationHttpMethod: POST
        Uri: !Sub 'arn:aws:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${GetProductsFunction.Arn}/invocations'

  # Déploiement avec CACHE (Tâche 3 de ta mission)
  ApiDeployment:
    Type: 'AWS::ApiGateway::Deployment'
    DependsOn: [ApiMethod]
    Properties:
      RestApiId: !Ref MissionApi

  ApiStage:
    Type: 'AWS::ApiGateway::Stage'
    Properties:
      RestApiId: !Ref MissionApi
      StageName: prod
      DeploymentId: !Ref ApiDeployment
      CacheClusterEnabled: true
      CacheClusterSize: '0.5'